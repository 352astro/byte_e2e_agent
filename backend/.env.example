# ── LLM 配置（必填） ──────────────────────────────────
LLM_API_KEY=sk-your-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_ID=your-model-id


SIDE_LLM_API_KEY=sk-yyy          # 不设 → 用 LLM_API_KEY
SIDE_LLM_BASE_URL=https://...     # 不设 → 用 LLM_BASE_URL
SIDE_LLM_MODEL_ID=deepseek-chat  # 不设 → 用 LLM_MODEL_ID

# ── Long-term memory（可选，默认关闭） ─────────────────
# MEMORY_ENABLED=0
# MEMORY_TOP_K=5
# MEMORY_RECALL_TOP_K=30
# MEMORY_LLM_TIMEOUT=10

# LLM_TIMEOUT=60                           # 可选，不设则使用 OpenAI SDK 默认值
# LLM_MAX_RETRIES=2                        # 可选，model_call 外层重试次数
# LLM_RETRY_BASE_DELAY_MS=800              # 可选，model_call 重试基础等待
# LLM_RETRY_MAX_DELAY_MS=8000              # 可选，model_call 重试最大等待
# LLM_STREAM_USAGE_ENABLED=1               # 可选，流式返回 usage 以统计 tokens
# LLM_METRICS_DB_PATH=.byte_agent/ai_metrics.sqlite3
# LLM_INPUT_COST_YUAN_PER_1M_TOKENS=3      # 可选，输入 token 单价（元/百万）
# LLM_OUTPUT_COST_YUAN_PER_1M_TOKENS=6     # 可选，输出 token 单价（元/百万）

# ── Agent 工作区（可选，默认 byte_e2e_agent 项目根） ───
# 相对路径以项目根（byte_e2e_agent/）为基准，与启动时的 cwd 无关
# AGENT_WORKSPACE=../conduit-realworld-example-app
# 使用过的 workspace 会登记在 byte_e2e_agent/.agent/workspaces.json（本地，已 gitignore）

# ── SerpApi 搜索（可选，不填则 Search 工具不可用） ───
SERPAPI_KEY=your-serpapi-key
