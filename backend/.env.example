# ── LLM 配置（必填） ──────────────────────────────────
LLM_API_KEY=sk-your-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_ID=your-model-id

# ── LLM 可选参数 ─────────────────────────────────────
# LLM_TIMEOUT=60
# LLM_MAX_RETRIES=3
# LLM_RETRY_BASE_DELAY_MS=800
# LLM_RETRY_MAX_DELAY_MS=8000

# ── LLM 成本定价默认值（未在 DB 中配置的模型会回退到这些值） ──
# LLM_INPUT_COST_YUAN_PER_1M_TOKENS=3
# LLM_OUTPUT_COST_YUAN_PER_1M_TOKENS=6
# LLM_REASONING_COST_YUAN_PER_1M_TOKENS=6

# ── Side LLM（memory 专用，不设则回退到主 LLM） ──────
# SIDE_LLM_API_KEY=sk-yyy
# SIDE_LLM_BASE_URL=https://...
# SIDE_LLM_MODEL_ID=deepseek-chat

# ── Long-term memory（可选，默认开启） ─────────────────
# MEMORY_ENABLED=1
# MEMORY_TOP_K=5
# MEMORY_RECALL_TOP_K=30
# MEMORY_LLM_TIMEOUT=10

# ── LLM 指标数据库路径 ──────────────────────────────
# LLM_METRICS_DB_PATH=.byte_agent/metrics.db

# ── Agent 工作区（可选，默认 byte_e2e_agent 项目根） ───
# 相对路径以项目根（byte_e2e_agent/）为基准，与启动时的 cwd 无关
# AGENT_WORKSPACE=../conduit-realworld-example-app
# 使用过的 workspace 会登记在 byte_e2e_agent/.byte_agent/workspaces.json（本地，已 gitignore）

# ── 浏览器工具 ───────────────────────────────────────
# BROWSER_HEADLESS=1

# ── SerpApi 搜索（可选，不填则 WebSearch 工具不可用） ──
# SERPAPI_KEY=your-serpapi-key
